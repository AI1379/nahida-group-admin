# ════════════════════════════════════════════════════════════
#  Nahida Group Admin 配置示例
#  复制为 .env 后按需修改：  cp .env.example .env
# ════════════════════════════════════════════════════════════

# ── NoneBot 运行配置 ──
# Driver 组合：
#   ~fastapi     ASGI 服务端，用于「反向 WS」/ Webhook（协议端主动连接机器人）
#   ~httpx       HTTP 客户端
#   ~websockets  WS 客户端，用于「正向 WS」（机器人主动连接协议端）
DRIVER=~fastapi+~httpx+~websockets

# 反向 WS / HTTP 服务监听地址（协议端连到这里）
HOST=127.0.0.1
PORT=8080

LOG_LEVEL=INFO

# 命令前缀，例如 /头衔
COMMAND_START=["/"]

# 超级用户（后续入群审批等授权功能会用到），填 QQ 号字符串
SUPERUSERS=[]

# ── OneBot V11 适配器（主后端）──
# 反向 WS：在 NapCat / Lagrange 等协议端里把上报地址设为
#   ws://<HOST>:<PORT>/onebot/v11/ws
# 若协议端设置了 access token，请在这里填写相同的值
ONEBOT_ACCESS_TOKEN=

# 正向 WS（可选，与反向 WS 二选一）：让机器人主动连接协议端时填写
# ONEBOT_WS_URLS=["ws://127.0.0.1:3001"]

# ── 自助头衔插件 ──
# 头衔最大字符数
TITLE_MAX_LENGTH=6
# 修改冷却（秒），0 表示不限制
TITLE_COOLDOWN=3600
# 禁止出现的子串，如 ["管理","群主"]
TITLE_BLACKLIST=[]

# ── 自助禁言插件 ──
# 允许普通成员禁言的「目标头衔」列表（例如 ["bot","机器人"]）
MUTABLE_TITLES=[]
# 普通成员单次禁言的最长时长（秒）；0 表示不限制
MUTE_MAX_DURATION_SECONDS=600
# 管理员/群主是否可无视「可禁言头衔」列表，禁言任意成员
MUTE_ADMIN_BYPASS=true

# ── 互动插件 ──
# 是否启用戳一戳互动（被戳时戳回去）
INTERACTION_POKE_ENABLED=true
# 是否启用关键词互动（匹配关键词时回复随机表情）
INTERACTION_KEYWORD_ENABLED=true
# 关键词列表（JSON 数组格式）
INTERACTION_KEYWORDS=["在吗","在不对","你好","hi","hello","晚安","早安","午安","安","早上好","晚上好","下午好"]
# 反应列表：混合 Unicode emoji 和 QQ face ID（JSON 数组，字符串为 emoji，整数为 face ID）
INTERACTION_REACTIONS=["😊","😄","🥰","😎","🤗","✨","💕","🌟","🎉","😇","🤭","😜","👻","👋","💖"]

# ── 陶片放逐插件 ──
# 是否启用陶片放逐功能
OSTRACISM_ENABLED=true
# 投票表情（字符串为 Unicode emoji，整数为 QQ face ID）
OSTRACISM_VOTE_EMOJI="🏺"
# 固定票数阈值；-1 表示不考虑此项
OSTRACISM_VOTES_FIXED=5
# 群成员百分比阈值（1-100）；-1 表示不考虑此项
OSTRACISM_VOTES_PERCENT=-1
# 投票有效时间窗（分钟）
OSTRACISM_WINDOW_MINUTES=30
